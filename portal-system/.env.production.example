# LinScio 门户系统 · 生产环境变量示例
# 用法：复制为 .env 并修改下列必填项，然后 chmod 600 .env
# 部署文档：docs/部署-腾讯云轻量与宝塔.md、docs/部署前检查-腾讯云香港宝塔.md

# ---------- 必填 ----------
# 数据库密码（首次启动后勿随意修改，否则需同步改库内密码或重建）
POSTGRES_PASSWORD=请替换为强密码

# JWT 签发密钥（建议 64 字符随机串，如：openssl rand -hex 32）
JWT_SECRET_KEY=请替换为64位随机字符串

# AES 加密密钥与 IV（Registry 密码等，32 字节 / 16 字节）
# 生成示例：openssl rand -base64 24 | head -c 32
AES_SECRET_KEY=请替换为32字节密钥
# 生成示例：openssl rand -base64 16 | head -c 16
AES_IV=请替换为16字节IV

# 镜像仓库对外地址（用户 docker login / pull 时使用）
# 有域名：registry.你的域名.com；暂用 IP：43.161.217.10:5000
REGISTRY_URL=registry.linscio.com.cn

# 前端 CORS 允许来源（JSON 数组，含门户与管理后台的完整 URL）
# 有域名示例：["https://www.你的域名.com","https://admin.你的域名.com","https://你的域名.com"]
# 暂用 IP 示例：["http://43.161.217.10:3000","http://43.161.217.10:3001"]
CORS_ORIGINS=["https://www.linscio.com.cn","https://admin.linscio.com.cn","https://linscio.com.cn"]

# 环境标识
ENVIRONMENT=production

# ---------- 可选 ----------
# 腾讯云 COS（下载中心安装包等），不配置则下载相关接口提示「下载服务暂未配置」
# COS_SECRET_ID=你的SecretId
# COS_SECRET_KEY=你的SecretKey
# COS_BUCKET=linscio-registry-1363203425
# COS_REGION=ap-hongkong

# Registry 独立 JWT 密钥（与门户/管理 JWT 隔离，生产建议设置）
# REGISTRY_JWT_SECRET=另一组随机字符串

# 数据/备份目录（可选），如 /www/wwwroot/linscio/data
# DATA_DIR=/www/wwwroot/linscio/data
