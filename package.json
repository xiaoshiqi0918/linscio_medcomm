{
  "name": "linscio-medcomm",
  "version": "0.1.1",
  "description": "LinScio MedComm - 医学科普写作智能体桌面客户端",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "backend": "cd backend && python run.py",
    "electron:dev": "NODE_ENV=development concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on tcp:127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "electron:dev:bypass": "MEDCOMM_DEV_BYPASS_AUTH=1 NODE_ENV=development concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on tcp:127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "electron:dev:electron-only": "NODE_ENV=development env -u ELECTRON_RUN_AS_NODE electron .",
    "electron:dev:dist": "npm run build && MEDCOMM_RENDERER=dist NODE_ENV=development env -u ELECTRON_RUN_AS_NODE electron .",
    "electron:dev:dist:bypass": "npm run build && MEDCOMM_RENDERER=dist MEDCOMM_DEV_BYPASS_AUTH=1 NODE_ENV=development env -u ELECTRON_RUN_AS_NODE electron .",
    "prebuild:python": "node scripts/download-python-standalone.js",
    "prebuild:wheels": "node scripts/build-wheels.js",
    "prebuild:comfyui": "node scripts/download-comfyui.js",
    "electron:build": "npm run prebuild:python && npm run prebuild:comfyui && bash scripts/preelectron-build.sh && vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "medical",
    "science",
    "popularization",
    "electron",
    "vue"
  ],
  "author": "LinScio",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@tiptap/extension-placeholder": "^2.1.0",
    "@tiptap/starter-kit": "^2.1.0",
    "@tiptap/vue-3": "^2.1.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.6.0",
    "echarts": "^5.4.0",
    "element-plus": "^2.5.0",
    "keytar": "^7.9.0",
    "pdfjs-dist": "^5.5.207",
    "pinia": "^2.1.0",
    "v-viewer": "^3.0.0",
    "viewerjs": "^1.11.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^24.9.0",
    "sass": "^1.69.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.linscio.medcomm",
    "productName": "LinScio MedComm",
    "directories": {
      "output": "releases/v${version}"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "backend/**/*",
      "build/wheels/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "backend/**/*",
      "build/wheels/**/*"
    ],
    "extraResources": [
      {
        "from": "build/python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/comfyui",
        "to": "comfyui",
        "filter": [
          "**/*"
        ]
      }
    ],
    "protocols": [
      {
        "name": "LinScio Deep Link",
        "schemes": [
          "linscio"
        ]
      }
    ],
    "artifactName": "LinScio-MedComm-${version}-${platform}-${arch}.${ext}",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.medical"
    },
    "dmg": {
      "artifactName": "LinScio-MedComm-${version}-mac-${arch}.dmg"
    },
    "nsis": {
      "artifactName": "LinScio-MedComm-${version}-win-x64.exe"
    },
    "portable": {
      "artifactName": "LinScio-MedComm-${version}-win-x64-portable.exe"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "appImage": {
      "artifactName": "LinScio-MedComm-${version}-linux-x64.AppImage"
    }
  }
}
