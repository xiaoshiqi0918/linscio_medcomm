# ═══════════════════════════════════════════════════════════
# LinScio MedComm .gitignore
# ═══════════════════════════════════════════════════════════

# ── 依赖 ──
node_modules/

# ── 构建产物 ──
dist/
release/
releases/

# ── 日志 ──
*.log
npm-debug.log*

# ── 环境变量 / 密钥（绝不提交） ──
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.p12
*.pfx

# ── Python ──
*.pyc
__pycache__/
.venv/
venv/

# ── 数据库（用户数据，由运行时生成） ──
*.db
*.db-journal
*.db-wal
*.db-shm

# ── 系统文件 ──
.DS_Store
Thumbs.db
*.swp
*~

# ── IDE ──
.idea/
.vscode/
*.code-workspace

# ── 测试 / 分析 ──
.pytest_cache/
.mypy_cache/
coverage/

# ── 应用数据（运行时生成，勿提交） ──
*.linscio-backup
.data/
backend/.data/

# ── 认证密钥（由后端在 APP_DATA 下自动生成） ──
backend/.auth_secret
backend/.data/.auth_secret

# ── Docker / 门户子系统 ──
portal-system/registry/auth/htpasswd
portal-system.zip

# ── 构建资源（体积大，本地或 CI 生成） ──
build/python/
build/*.tar.gz
build/*.zip
build/wheels/*
!build/wheels/README.md
!build/wheels/.gitkeep

# ── ComfyUI 引擎 + 模型（~5GB，本地下载或 bundle 方式） ──
build/comfyui/

# ── VC++ Redistributable 安装包（~25MB，CI 自动下载） ──
build/vc_redist.x64.exe
